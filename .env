# PostgreSQL Configuration  for the Docker Container 
POSTGRES_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/devlinks

# MongoDB Configuration (localhost for host machine access)
MONGO_URL=mongodb://localhost:27018/devlinks
MONGO_DB_NAME=devlinks

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# JWT 
SECRET_KEY=your-super-secret-key-change-this-to-something-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Application Configuration
APP_HOST=127.0.0.1
APP_PORT=8000
BASE_URL=http://localhost:8000

# CORS Configuration (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000
