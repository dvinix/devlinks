# PostgreSQL (use localhost when running app outside Docker, or postgres when inside Docker)
POSTGRES_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/devlinks

# MongoDB (use localhost when running app outside Docker, or mongo when inside Docker)
MONGO_URL=mongodb://admin:root@localhost:27017/devlinks?authSource=admin
MONGO_DB_NAME=devlinks

# Redis (use localhost when running app outside Docker, or redis when inside Docker)
REDIS_URL=redis://localhost:6379/0

# JWT Configuration
SECRET_KEY=CHANGE_ME_TO_RANDOM_STRING_AT_LEAST_32_CHARACTERS_LONG
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Application Configuration
APP_HOST=127.0.0.1
APP_PORT=8000
BASE_URL=http://localhost:8000

# CORS Configuration (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000